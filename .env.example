# ============================================================
# GitViz Pro — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values.
# cp .env.example .env.local
# ============================================================

# GitHub OAuth App (https://github.com/settings/developers)
# Create a new OAuth App with:
#   Homepage URL: http://localhost:3000
#   Callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Auth.js Secret — generate with: openssl rand -hex 32
AUTH_SECRET=

# GitHub Personal Access Token — NO scopes needed (public data only)
# Provides 5,000 req/hr for server-side unauthenticated requests
# Create at: https://github.com/settings/tokens
GITHUB_PAT=

# Upstash Redis (https://console.upstash.com/)
# Create a free Redis database and copy the REST credentials
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
